class Solution {
public:
    Node* copyRandomList(Node* head) {
        //Create cloned nodes
        Node *temp=head;
        Node *cloneHead=nullptr;
        Node *cloneTail=nullptr;
        while(temp){
            Node *newNode=new Node(temp->val);
            if(cloneHead==nullptr){
                cloneHead=newNode;
                cloneTail=newNode;
            }
            else{
                cloneTail->next=newNode;
                cloneTail=cloneTail->next;
            }
            temp=temp->next;
        }
        //Interleave original and cloned nodes
        Node *originalNode=head,*cloneNode=cloneHead;
        while(originalNode && cloneNode){
            Node *next = originalNode->next;
            originalNode->next=cloneNode;
            originalNode=next;
            next=cloneNode->next;
            cloneNode->next=originalNode;
            cloneNode=next;
        }
        //Assign random pointers
        temp=head;
        while(temp){
            if(temp->next){
                temp->next->random=temp->random ? temp->random->next : temp->random;
            }
            temp=temp->next->next;
        }
        //Separate the lists
        originalNode=head,cloneNode=cloneHead;
        while(originalNode && cloneNode){
            originalNode->next=cloneNode->next;
            originalNode=originalNode->next;
            if(cloneNode->next)cloneNode->next=originalNode->next;
            cloneNode=cloneNode->next;
        }
        return cloneHead;
    }
};
