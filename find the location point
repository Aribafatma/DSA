#include <iostream>

using namespace std;

int main() {
    long long x, y;
    
    // Read the input coordinates
    if (!(cin >> x >> y)) return 0;

    // Check conditions based on the problem description
    if (x == 0 && y == 0) {
        cout << "Origin" << endl;
    } 
    else if (y == 0 && x != 0) {
        cout << "X axis" << endl;
    } 
    else if (x == 0 && y != 0) {
        cout << "Y axis" << endl;
    } 
    else if (x > 0 && y > 0) {
        cout << "1st Quadrant" << endl;
    } 
    else if (x < 0 && y > 0) {
        cout << "2nd Quadrant" << endl;
    } 
    else if (x < 0 && y < 0) {
        cout << "3rd Quadrant" << endl;
    } 
    else if (x > 0 && y < 0) {
        cout << "4th Quadrant" << endl;
    }

    return 0;
}
