#include <bits/stdc++.h>
using namespace std;

const int MAXN = 200000;
int spf[MAXN + 1];

void sieve() {
    for (int i = 1; i <= MAXN; i++) spf[i] = i;

    for (int i = 2; i * i <= MAXN; i++) {
        if (spf[i] == i) { // prime
            for (int j = i * i; j <= MAXN; j += i) {
                if (spf[j] == j)
                    spf[j] = i;
            }
        }
    }
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(NULL);

    sieve();

    int Q;
    cin >> Q;

    while (Q--) {
        int n, k;
        cin >> n >> k;

        int count = 0;
        while (n > 1) {
            int p = spf[n];
            count++;
            if (count == k) {
                cout << p << '\n';
                break;
            }
            n /= p;
        }

        if (count < k) cout << -1 << '\n';
    }

    return 0;
}
