#include <iostream>
#include <vector>
#include <algorithm>
#include <cmath>

using namespace std;

int main() {
    // Faster I/O
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    long long n, k;
    if (!(cin >> n >> k)) return 0;

    vector<long long> factors;

    // Iterate up to sqrt(n)
    for (long long i = 1; i * i <= n; ++i) {
        if (n % i == 0) {
            factors.push_back(i);
            // If i is not the square root, add the paired factor n/i
            if (i * i != n) {
                factors.push_back(n / i);
            }
        }
    }

    // Sort factors in ascending order
    sort(factors.begin(), factors.end());

    // Check if the k-th factor exists
    if (k > factors.size()) {
        cout << -1 << endl;
    } else {
        // Output k-th factor (using 0-based indexing for vector)
        cout << factors[k - 1] << endl;
    }

    return 0;
}
