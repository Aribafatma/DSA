#include <iostream>
#include <vector>
#include <set>
#include <algorithm>

using namespace std;

int main() {
    // Optimize I/O operations
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int n;
    if (!(cin >> n)) return 0;

    vector<int> a(n);
    for (int i = 0; i < n; i++) {
        cin >> a[i];
    }

    set<int> current_streak;
    int max_len = 0;
    int left = 0;

    for (int right = 0; right < n; right++) {
        // If the ID is already in the current streak, shrink from the left
        while (current_streak.count(a[right])) {
            current_streak.erase(a[left]);
            left++;
        }
        
        // Add the current ID and update the maximum length
        current_streak.insert(a[right]);
        max_len = max(max_len, right - left + 1);
    }

    cout << max_len << endl;

    return 0;
}
