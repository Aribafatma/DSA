#include <iostream>
#include <set>
using namespace std;

int main() {
    int n, m;
    cin >> n;

    set<int> s;
    int x;

    // First array
    for (int i = 0; i < n; i++) {
        cin >> x;
        s.insert(x);
    }

    cin >> m;

    // Second array
    for (int i = 0; i < m; i++) {
        cin >> x;
        s.insert(x);
    }

    // Output
    cout << s.size() << endl;

    bool first = true;
    for (set<int>::iterator it = s.begin(); it != s.end(); it++) {
        if (!first) cout << " ";
        cout << *it;
        first = false;
    }

    cout << endl;

    return 0;
}
