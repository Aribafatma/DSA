#include <iostream>
using namespace std;

int main() {
    int n, h;
    cin >> n >> h;

    int totalWidth = 0;
    for (int i = 0; i < n; i++) {
        int height;
        cin >> height;
        if (height > h) {
            totalWidth += 2;  // friend bends → width = 2
        } else {
            totalWidth += 1;  // normal walking → width = 1
        }
    }

    cout << totalWidth << endl;
    return 0;
}
